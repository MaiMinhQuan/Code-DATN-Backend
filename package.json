{
  "name": "ielts-writing-backend",
  "version": "1.0.0",
  "description": "IELTS Writing Task 2 E-learning Platform with AI Grading",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "docker:up": "docker start mongodb redis || (docker run -d -p 27017:27017 --name mongodb mongo:latest && docker run -d -p 6379:6379 --name redis redis:latest)",
    "docker:down": "docker stop mongodb redis",
    "docker:reset": "docker stop mongodb redis && docker rm mongodb redis && docker run -d -p 27017:27017 --name mongodb mongo:latest && docker run -d -p 6379:6379 --name redis redis:latest",
    "docker:logs": "docker logs mongodb && docker logs redis",
    "db:shell": "docker exec -it mongodb mongosh",
    "redis:cli": "docker exec -it redis redis-cli"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/mongoose": "^10.0.2",
    "@nestjs/websockets": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/bullmq": "^10.0.1",
    "@google/generative-ai": "^0.2.1",
    "mongoose": "^8.0.3",
    "bullmq": "^5.1.0",
    "ioredis": "^5.3.2",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "bcrypt": "^5.1.1",
    "socket.io": "^4.6.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/bcrypt": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
