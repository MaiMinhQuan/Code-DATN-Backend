# YouTube Data API v3
# Lấy tại: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenRouter API (dùng cho AI extraction — Step 3+)
# Lấy tại: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model mặc định (tiết kiệm, hỗ trợ tiếng Việt tốt)
# Có thể đổi sang: mistralai/mistral-7b-instruct, meta-llama/llama-3.1-8b-instruct, v.v.
OPENROUTER_MODEL=google/gemini-2.0-flash-lite

# DeepL API (miễn phí 500K ký tự/tháng)
# Lấy tại: https://www.deepl.com/pro-api
DEEPL_API_KEY=your_deepl_api_key_here

# MongoDB (để seed kết quả vào DB)
MONGODB_URI=mongodb://localhost:27017/ielts-writing-db
